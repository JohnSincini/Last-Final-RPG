public class Personaggio extends Creatura {
    private final String classe;
    private int livello;
    private int forza;
    private int intelletto;
    private int destrezza;

    public Personaggio(String classe, String nome, int vitaMassima, Azione[] combatti, int livello, int forza, int intelletto, int destrezza) {
        super(nome, vitaMassima, combatti);
        this.classe = classe;
        this.livello = livello;
        this.forza = forza;
        this.intelletto = intelletto;
        this.destrezza = destrezza;
    }

    public String getClasse() {
        return classe;
    }

    public int getLivello() {
        return livello;
    }

    public int getForza() {
        return forza;
    }

    public int getIntelletto() {
        return intelletto;
    }

    public int getDestrezza() {
        return destrezza;
    }

    public void setLivello(int livello) {
        this.livello = livello;
    }

    public void setForza(int forza) {
        this.forza = forza;
    }

    public void setIntelletto(int intelletto) {
        this.intelletto = intelletto;
    }

    public void setDestrezza(int destrezza) {
        this.destrezza = destrezza;
    }
    
}